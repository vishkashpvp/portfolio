{
  "name": "portfolio",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "prepare": "husky install",
    "check-types": "tsc --pretty -noEmit",
    "check-lint": "eslint .",
    "check-format": "prettier . --check",
    "format": "prettier . --write --cache",
    "test-all": "npm run check-format && npm run check-lint && npm run check-types && npm run build",
    "clean": "rm -rf .next out .turbo node_modules/.cache"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "react": "^19",
    "react-dom": "^19",
    "simple-icons": "^16.15.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "postcss": "^8",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6"
  }
}
